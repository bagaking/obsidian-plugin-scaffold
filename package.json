{
	"name": "obsidian-plugin-scaffold-sample",
	"version": "0.1.0",
	"description": "This is a sample plugin for Obsidian (https://obsidian.md)",
	"main": "build/main.js",
	"scripts": {
		"dev": "node ./scripts/esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node ./scripts/esbuild.config.mjs production",
		"dogfood": "tsc -noEmit -skipLibCheck && node ./scripts/esbuild.config.mjs dogfood && sh ./scripts/dogfood.sh",
		"version": "git add manifest.json versions.json",
		"test": "node --test scripts/*.test.mjs",
		"pack:dry-run": "npm pack --dry-run --json",
		"pack:check": "node scripts/check-pack.mjs",
		"lint": "eslint ./src/**/*.ts"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bagaking/obsidian-plugin-scaffold.git"
	},
	"homepage": "https://github.com/bagaking/obsidian-plugin-scaffold#readme",
	"bugs": {
		"url": "https://github.com/bagaking/obsidian-plugin-scaffold/issues"
	},
	"dependencies": {
		"@ant-design/plots": "^1.2.3",
		"antd": "^5.1.2",
		"debug": "^4.3.4",
		"file-type": "^18.0.0",
		"filenamify": "^5.1.1",
		"got": "^12.5.3",
		"is-svg": "^4.3.2",
		"moment": "^2.29.4",
		"obsidian-daily-notes-interface": "^0.9.4",
		"path": "^0.12.7",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"safe-regex": "^2.1.1",
		"ts-xxhash": "^1.0.6",
		"yaml": "^2.2.1"
	},
	"devDependencies": {
		"@types/debug": "^4.1.7",
		"@types/node": "^18.11.17",
		"@types/react": "^18.0.26",
		"@types/react-dom": "^18.0.10",
		"@types/safe-regex": "^1.1.4",
		"@typescript-eslint/eslint-plugin": "^5.62.0",
		"@typescript-eslint/parser": "^5.62.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.14.47",
		"eslint": "^8.57.1",
		"json": "^11.0.0",
		"obsidian": "latest",
		"prettier": "^2.8.1",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
